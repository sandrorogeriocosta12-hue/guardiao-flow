# Ambiente
ENV=development

# Banco de dados PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/guardiaoflow

# Segurança
SECRET_KEY=sua-chave-secreta-super-segura-aqui-minimo-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8001,http://localhost:8000

# Redis
REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
